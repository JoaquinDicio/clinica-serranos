---
const { lang = "ES" } = Astro.props;
import ProceduresSlider from "./ProceduresSlider.astro";
import SliderReviews from "./SliderReviews.astro";
import Title from "./Title.astro";

const data = {
    ES: {
        title: "Te mostramos resultados de nuestros pacientes",
        text: "En la Clínica Dental Serrano estudiamos cada caso de manera personalizada, con el objetivo de conseguir los mejores resultados en cada tratamiento.",
        moreResults: "¿Quieres ver más resultados?",
        instagram: "siguenos en instagram",
        firstVisit: "Primera visita y diagnostico sin coste",
        contact: "CONTACTAR",
        reviews: "¿Qué opinan de nosotros?",
    },

    EN: {
        title: "Results from our patients",
        text: "At Clínica Dental Serrano we study each case in a personalized way in order to achieve the best results in every treatment.",
        moreResults: "Want to see more results?",
        instagram: "follow us on instagram",
        firstVisit: "First visit and diagnosis at no cost",
        contact: "CONTACT",
        reviews: "What do our patients think about us?",
    },

    RU: {
        title: "Результаты наших пациентов",
        text: "В клинике Serrano мы рассматриваем каждый случай индивидуально, чтобы добиться наилучших результатов в каждом лечении.",
        moreResults: "Хотите увидеть больше результатов?",
        instagram: "подписывайтесь в instagram",
        firstVisit: "Первый визит и диагностика бесплатно",
        contact: "СВЯЗАТЬСЯ",
        reviews: "Что о нас говорят пациенты?",
    },
};

const t = data[lang] ?? data.ES;
---

<section
    id="work-examples"
    class="flex flex-col text-white bg-[var(--secondary-color)] pt-14 items-center"
>
    <Title lightMode={true} extraClasses="p-10" title={t.title} />

    <p class="text-center pb-10 px-10 max-w-[650px]">
        {t.text}
    </p>

    <ProceduresSlider lang={lang} />

    <div
        data-aos="fade-up"
        class="h-[40vh] mb-10 flex text-center items-center justify-center flex-col"
    >
        <p class="text-xl font-bold">{t.moreResults}</p>

        <a
            href="https://www.instagram.com/clinicadentalserranos/"
            class="rounded-full border-white border-2 mt-5 py-2 px-3 text-center uppercase"
        >
            {t.instagram}
        </a>
    </div>

    <div
        class="w-full bg-[url('/dentista-trabajando.jpg')] first-visit bg-cover"
    >
        <div
            class="py-14 md:py-20 w-full flex text-center items-center justify-center flex-col bg-black/50"
        >
            <h2 class="font-bold text-white text-2xl px-12">
                {t.firstVisit}
            </h2>

            <a
                href="https://wa.me/message/R5MXKI5CQE23F1"
                target="_blank"
                class="rounded-full text-white bg-[var(--secondary-color)] uppercase font-medium px-12 my-7 py-2"
            >
                {t.contact}
            </a>

            <span class="font-bold text-4xl rotate-90 text-white">:)</span>
        </div>
    </div>
</section>

<style>
    .first-visit {
        width: 100%;
        background-repeat: no-repeat;
        background-position: 0 -150px;
    }
    @media (min-width: 550px) {
        .first-visit {
            background-position: 0 -670px;
        }
    }
</style>
