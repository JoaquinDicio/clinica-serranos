---
const { lang = "es" } = Astro.props;
import ProcedurePost from "./ProcedurePost.astro";

const POSTS = {
  es: [
    {
      title: "Rehabilitación Adhesiva",
      description:
        "Combinación de carillas, carillas 360, vonlays, recambio de coronas metal cerámicas y coronas de zirconia sobre implantes",
      photo_url: "/procedimientos/procedimiento-1.jpg",
    },
    {
      title: "Recambio de coronas",
      description:
        "Recambio antiguas coronas metal cerámicas por coronas de cerámica pura con base de zirconio opaco y estratificación.",
      photo_url: "/procedimientos/procedimiento-2.jpg",
    },
    {
      title: "Alineadores + Blanqueamiento",
      description:
        "Tratamiento integral, estético y establecimiento de guía anterior con entrecruzamiento",
      photo_url: "/procedimientos/procedimiento-3.jpg",
    },
    {
      title: "Tratamiento con carillas cerámicas",
      description:
        "Convertimos los laterales en centrales y caninos en laterales con carillas con un color natural",
      photo_url: "/procedimientos/procedimiento-4.jpg",
    },
    {
      title: "Rehabilitación carillas cerámicas",
      description:
        "Rehabilitación en carillas cerámicas combinada con alineadores para descruzar mordida.",
      photo_url: "/procedimientos/procedimiento-5.jpg",
    },
    {
      title: "Rehabilitación con implantes",
      description:
        "Rehabilitación combinada utilizando implantes, cirugía guiada, injertos de tejido y coronas en zirconia.",
      photo_url: "/procedimientos/procedimiento-6.jpg",
    },
    {
      title: "Cierre de triángulos",
      description:
        "Cierre de triángulos negros entre dientes con resina, mejorando la estética.",
      photo_url: "/procedimientos/procedimiento-7.jpg",
    },
    {
      title: "Resolución de malposiciones",
      description:
        "4 meses con alineadores invisibles + blanqueamiento + modificación de forma con resina",
      photo_url: "/procedimientos/procedimiento-8.jpg",
    },
    {
      title: "Rehabilitación en bruxismo severo",
      description:
        "Reconstrucción de piezas con cerámica para lograr buena estética y resistencia. Se colocaron implantes en piezas ausentes.",
      photo_url: "/procedimientos/procedimiento-9.jpg",
    },
  ],

  en: [
    {
      title: "Adhesive Rehabilitation",
      description:
        "Combination of veneers, 360 veneers, vonlays, replacement of metal-ceramic crowns and zirconia crowns on implants.",
      photo_url: "/procedimientos/procedimiento-1.jpg",
    },
    {
      title: "Replacement of Crowns",
      description:
        "Replacement of old metal-ceramic crowns with pure ceramic crowns and opaque zirconium base.",
      photo_url: "/procedimientos/procedimiento-2.jpg",
    },
    {
      title: "Aligners + Whitening",
      description:
        "Comprehensive aesthetic treatment and establishment of anterior guidance.",
      photo_url: "/procedimientos/procedimiento-3.jpg",
    },
    {
      title: "Ceramic Veneer Treatment",
      description:
        "Turning laterals into centrals and canines into laterals using natural-looking veneers.",
      photo_url: "/procedimientos/procedimiento-4.jpg",
    },
    {
      title: "Ceramic Veneer Rehabilitation",
      description:
        "Rehabilitation with ceramic veneers combined with aligners to correct bite crossing.",
      photo_url: "/procedimientos/procedimiento-5.jpg",
    },
    {
      title: "Implant Rehabilitation",
      description:
        "Combined rehabilitation using implants, guided surgery, tissue grafts and zirconia crowns.",
      photo_url: "/procedimientos/procedimiento-6.jpg",
    },
    {
      title: "Closing Black Triangles",
      description:
        "Closing black triangles between teeth with resin to improve aesthetics.",
      photo_url: "/procedimientos/procedimiento-7.jpg",
    },
    {
      title: "Correction of Malpositions",
      description:
        "4 months with invisible aligners + whitening + shape modification with resin.",
      photo_url: "/procedimientos/procedimiento-8.jpg",
    },
    {
      title: "Severe Bruxism Rehabilitation",
      description:
        "Ceramic reconstruction for strength and aesthetics, with implants replacing missing teeth.",
      photo_url: "/procedimientos/procedimiento-9.jpg",
    },
  ],

  ru: [
    {
      title: "Адгезивная реабилитация",
      description:
        "Комбинация виниров, виниров 360°, вкладок vonlay, замены металлокерамических коронок и циркониевых коронок на имплантах.",
      photo_url: "/procedimientos/procedimiento-1.jpg",
    },
    {
      title: "Замена коронок",
      description:
        "Замена старых металлокерамических коронок на полностью керамические коронки с основой из циркония.",
      photo_url: "/procedimientos/procedimiento-2.jpg",
    },
    {
      title: "Элайнеры + отбеливание",
      description:
        "Комплексное эстетическое лечение и формирование правильной передней окклюзии.",
      photo_url: "/procedimientos/procedimiento-3.jpg",
    },
    {
      title: "Лечение керамическими винирами",
      description:
        "Боковые резцы преобразуются в центральные, а клыки — в боковые с помощью виниров естественного цвета.",
      photo_url: "/procedimientos/procedimiento-4.jpg",
    },
    {
      title: "Реабилитация керамическими винирами",
      description:
        "Реабилитация винирами в сочетании с элайнерами для исправления прикуса.",
      photo_url: "/procedimientos/procedimiento-5.jpg",
    },
    {
      title: "Реабилитация с имплантами",
      description:
        "Комплексная реабилитация с использованием имплантов, направляемой хирургии, трансплантации тканей и циркониевых коронок.",
      photo_url: "/procedimientos/procedimiento-6.jpg",
    },
    {
      title: "Закрытие чёрных треугольников",
      description:
        "Закрытие чёрных промежутков между зубами композитом для улучшения эстетики.",
      photo_url: "/procedimientos/procedimiento-7.jpg",
    },
    {
      title: "Коррекция положения зубов",
      description:
        "4 месяца с прозрачными элайнерами + отбеливание + изменение формы зубов композитом.",
      photo_url: "/procedimientos/procedimiento-8.jpg",
    },
    {
      title: "Реабилитация при тяжёлом бруксизме",
      description:
        "Восстановление зубов керамикой для прочности и эстетики с установкой имплантов.",
      photo_url: "/procedimientos/procedimiento-9.jpg",
    },
  ],
};

const POSTS_PROCEDURES = POSTS[lang] ?? POSTS.es;
---

<!-- Swiper -->
<div class="swiper mySwiperProcedures">
  <div class="swiper-wrapper">
    {
      POSTS_PROCEDURES.map((post) => (
        <div class="swiper-slide">
          <ProcedurePost
            photo_url={post.photo_url}
            title={post.title}
            description={post.description}
          />
        </div>
      ))
    }
  </div>
</div>

<!-- Initialize Swiper -->
<script>
  //this error should be ignored, its a editor thing
  import Swiper from "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.mjs";

  var swiper = new Swiper(".mySwiperProcedures", {
    slidesPerView: 1,
    spaceBetween: 10,
    autoplay: {
      delay: 5000,
      disableOnInteraction: true,
    },
    breakpoints: {
      640: {
        slidesPerView: 1,
        spaceBetween: 20,
      },
      767: {
        slidesPerView: 2,
        spaceBetween: 10,
      },
      1024: {
        slidesPerView: 3,
        spaceBetween: 50,
      },
      1600: {
        slidesPerView: 4,
        spaceBetween: 50,
      },
    },
  });
</script>
<style>
  @import url("https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css");
  div.swiper {
    cursor: grab;
    margin-top: 70px;
    height: 100%;
    background: transparent;
    padding: 0 30px;
  }

  .swiper {
    width: 100%;
    height: 100%;
    margin-top: 50px;
  }

  .swiper-slide {
    text-align: center;
    font-size: 18px;
    height: fit-content;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .swiper-slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
