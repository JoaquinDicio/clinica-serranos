---
import Layout from "../layouts/Layout.astro";

// componentes
import Header from "../components/Header.astro";
import Title from "../components/Title.astro";
import Footer from "../components/Footer.astro";
import SliderReviews from "../components/SliderReviews.astro";
import AboutUs from "../components/AboutUs.astro";
import ProceduresSlider from "../components/ProceduresSlider.astro";
import Home from "../components/Home.astro";
import Divider from "../components/Divider.astro";
import Services from "../components/Services.astro";

const lang = "ES";
---

<Layout
  description="Clínica dental en Valencia: Expertos en cuidar tu sonrisa. Ofrecemos servicios de limpieza, blanqueamiento, ortodoncia, implantes y alineadores. ¡Agenda tu cita hoy!"
  title="Serranos - Clinica Dental"
>
  <main>
    <Header lang={lang} />
    <main>
      <!-- HOME -->
      <Home lang={lang} />
      <!-- SOBRE NOSOTROS - ABOUT US -->
      <AboutUs lang={lang} />
      <!-- DIVIDER -->
      <Divider lang={lang} />
      <!-- SERVICIOS - SERVICES -->
      <Services lang={lang} />
      <!-- FLUJO DE TRABAJO - WORKFLOW -->
      <section
        id="work-flow"
        class="bg-[url('/trabajo-precision.jpg')] text-center bg-cover bg-center m-0"
      >
        <div class="bg-[#273047]/70 w-full h-[70px]"></div>
        <div
          class="text-center flex flex-col text-white gap-10 py-16 md:py-20 bg-black/70"
        >
          <h3 class="font-medium text-2xl">Flujo de trabajo 100% digital</h3>
          <p class="px-10 md:max-w-[550px] mx-auto">
            Experimente nuestro innovador flujo de trabajo totalmente digital en
            nuestra clínica dental.
          </p>
          <p class="px-10 font-medium md:max-w-[550px] mx-auto">
            La sonrisa de tus sueños hecha realidad con tecnología de vanguardia
          </p>
          <div class="bg-[#273047]/70 w-full py-4 text-white">
            <p class="uppercase md:text-xl">el diseño de tu sonrisa</p>
            <span class="font-bold uppercase md:text-xl">listo en el dia</span>
          </div>
        </div>
      </section>
      <!-- WORK EXAMPLES -->
      <section
        id="work-examples"
        class="flex flex-col text-white bg-[var(--secondary-color)] pt-14 items-center"
      >
        <Title
          lightMode={true}
          extraClasses="p-10"
          title="Te mostramos resultados de nuestros pacientes"
        />
        <p class="text-center pb-10 px-10 max-w-[650px]">
          En la Clínica Dental Serrano estudiamos cada caso de manera
          personalizada, con el objetivo de conseguir los mejores resultados en
          cada tratamiento.
        </p>
        <ProceduresSlider />
        <div
          class="h-[40vh] mb-10 flex text-center items-center justify-center flex-col"
        >
          <p class="text-xl font-bold">¿Quieres ver más resultados?</p>
          <a
            href="https://www.instagram.com/clinicadentalserranos/"
            class="rounded-full border-white border-2 mt-5 py-2 px-3 text-center uppercase"
            >siguenos en instagram</a
          >
        </div>
        <div
          class="w-full bg-[url('/dentista-trabajando.jpg')] first-visit bg-cover"
        >
          <div
            class="py-14 md:py-20 w-full flex text-center items-center justify-center flex-col bg-black/50"
          >
            <h2 class="font-bold text-white text-2xl px-12">
              Primera visita y diagnostico sin coste
            </h2>
            <a
              href="https://wa.me/message/R5MXKI5CQE23F1"
              target="_blank"
              class="rounded-full text-white bg-[var(--secondary-color)] uppercase font-medium px-12 my-7 py-2"
              >CONTACTAR</a
            >
            <span class="font-bold text-4xl rotate-90 text-white">:)</span>
          </div>
        </div>
        <div class="w-full px-5 flex flex-col items-center">
          <p class="text-xl font-bold text-center mt-10">
            ¿Qué opinan de nosotros?
          </p>

          <SliderReviews />
        </div>
      </section>
      <!-- CONTACTO -->
      <section id="contacto" class="pt-20">
        <Title extraClasses="mb-10 px-10" title="¿Qué estás esperando?" />
        <p class="text-center mb-5 px-10 md:max-w-[600px] mx-auto">
          No permitas que el miedo o la indecisión te impidan alcanzar la
          sonrisa que siempre has deseado.
        </p>
        <p class="font-bold text-md text-center px-10 md:max-w-[700px] mx-auto">
          ¡Contáctanos hoy mismo para programar una consulta y dar el primer
          paso hacia una sonrisa más saludable y hermosa!
        </p>
        <div class="flex justify-center mt-10 px-10">
          <a
            href="https://www.instagram.com/clinicadentalserranos/"
            class="fa-brands fa-instagram text-[var(--main-color)] mr-4 text-5xl"
          ></a>
          <a
            href="https://wa.me/message/R5MXKI5CQE23F1"
            target="_blank"
            class="fa-brands fa-whatsapp text-[var(--main-color)] text-5xl"></a>
        </div>
        <div class="bg-[var(--main-color)] h-full pb-20 rounded-t-[25px]">
          <div
            class="h-[330px] md:h-[500px] overflow-hidden rounded-[25px] bg-gray-600 mt-20 flex justify-center items-center"
          >
            <iframe
              class="h-full w-screen"
              src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d12317.774512279668!2d-0.3752216!3d39.4818962!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd604895ea631a8d%3A0x6358d0e1dcd9f492!2sCl%C3%ADnica%20Dental%20Serranos!5e0!3m2!1ses!2sar!4v1713497921283!5m2!1ses!2sar"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>
      </section>
    </main>
  </main>
  <Footer lang="es" />
</Layout>

<style>
  .first-visit {
    width: 100%;
    background-repeat: no-repeat;
    background-position: 0 -150px;
  }
  @media (min-width: 550px) {
    .first-visit {
      background-position: 0 -670px;
    }
  }
</style>
