---
interface Props {
  title: string;
  description: string;
  lang?: "EN" | "ES" | "RU";
  showLegal?: boolean;
}

const {
  title,
  description = "description",
  lang = "ES",
  showLegal = true,
} = Astro.props;

import Whatsapp from "../components/Whatsapp.astro";
import CookiesAgreement from "../components/CookiesAgreement.astro";

const translations = {
  ES: {
    ogDescription: "Sonríe con confianza con nuestra ayuda",
  },
  EN: {
    ogDescription: "Smile with confidence with our help",
  },
  RU: {
    ogDescription: "Улыбайтесь уверенно с нашей помощью",
  },
};

const t = translations[lang] ?? translations.ES;

const langMap = {
  ES: "es",
  EN: "en",
  RU: "ru",
};

const currentLang = langMap[lang] ?? "es";

const baseUrl = "https://dentalserranos.com";

const currentPath = Astro.url.pathname;

const canonical = baseUrl + currentPath;
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>

    <link rel="canonical" href={canonical} />

    <!-- ✅ HREFLANG (multi idioma) -->
    <link rel="alternate" href={`${baseUrl}/`} hreflang="es" />
    <link rel="alternate" href={`${baseUrl}/en/`} hreflang="en" />
    <link rel="alternate" href={`${baseUrl}/ru/`} hreflang="ru" />
    <link rel="alternate" href={`${baseUrl}/`} hreflang="x-default" />

    <!-- ✅ OPEN GRAPH -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={t.ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <!-- ✅ TWITTER -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={t.ogDescription} />

    <!-- ICON -->
    <link rel="icon" href="/logo-serranos.png" type="image/x-icon" />

    <!-- AOS (animaciones) -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

    <!-- SWIPER -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
    />

    <!-- Google Consent Mode (default denied) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];

      function gtag() {
        dataLayer.push(arguments);
      }

      gtag("js", new Date());
      gtag("config", "AW-17915866171");

      gtag("consent", "default", {
        ad_storage: "denied",
        analytics_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
      });
    </script>

    <!-- Google Tag Manager -->
    <script async src="https://www.googletagmanager.com/gtm.js?id=GTM-T6F4VGFC"
    ></script>
  </head>

  <body>
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-T6F4VGFC"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>

    <slot />

    <!-- FontAwesome -->
    <script
      src="https://kit.fontawesome.com/759a8eedd2.js"
      crossorigin="anonymous"></script>

    <!-- AOS -->
    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        AOS.init();
      });
    </script>

    <Whatsapp />
    {showLegal && <CookiesAgreement lang={lang} />}
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap");

  * {
    font-family: "Poppins", sans-serif;
    box-sizing: border-box;
    scroll-behavior: smooth;
    padding: 0;
    margin: 0;
  }

  :root {
    --secondary-color: #273047;
    --main-color: #273047;
    --funnel-secondary-color: #1e79fe;
    --funnel-primary-color: #d4efff;
  }
</style>
